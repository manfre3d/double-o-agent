# Copy to .env at the repo root. Control reads it via @nestjs/config;
# docker compose reads it for the Postgres container.

# Control
PORT=3000
# Signs the anonymous per-session cookie that isolates each visitor's missions.
# REQUIRED — Control refuses to boot without it. Generate one with:
#   openssl rand -hex 32
SESSION_COOKIE_SECRET=replace-with-openssl-rand-hex-32
# Missions (and their events) are purged this many hours after they start.
MISSION_RETENTION_HOURS=72

# OpenAI. Optional. With a real key, missions run live by default and visitors
# can still switch to demo per mission (HQ header toggle). If the key is missing
# or left as the placeholder, every mission runs on the scripted demo brain.
# DEMO_MODE=true forces demo mode globally even with a real key.
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
# DEMO_MODE=true

# Postgres — compose creates the container with these; DATABASE_URL must match.
POSTGRES_USER=doubleo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=double_o
DATABASE_URL=postgresql://doubleo:change-me@localhost:5432/double_o
