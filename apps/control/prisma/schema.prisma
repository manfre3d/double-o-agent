generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Mission {
  id         String    @id
  /// Anonymous session token that owns this mission; every read is scoped to it.
  /// Generic on purpose — a real user id can reuse this column later.
  ownerId    String
  code       String
  type       String
  status     String    @default("running")
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  /// Stored debrief prose (Italian, user-facing).
  debrief    String?
  /// FlaggedInvoiceDto[] as JSON.
  flagged    Json      @default("[]")
  /// ExtractedInvoiceDto as JSON (extraction missions only).
  extracted  Json?
  events     MissionEvent[]

  /// Per-owner code sequence, so each session gets its own 007-001…
  @@unique([ownerId, code])
  @@index([ownerId, startedAt])
}

model MissionEvent {
  id        Int      @id @default(autoincrement())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  seq       Int
  type      String
  /// The full wire-shape MissionEvent, replayed as-is for history.
  payload   Json
  at        DateTime

  @@unique([missionId, seq])
}
